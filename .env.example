# Terra Intelligence — Environment Variables Template
# Copy this file to .env and fill in your actual API keys
# NEVER commit .env — it is gitignored

# Groq API Key (primary AI — free tier available at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API Key (fallback AI — platform.openai.com)
OPENAI_API_KEY=your_openai_api_key_here

# OpenWeatherMap API Key (free tier at openweathermap.org/api)
OPENWEATHERMAP_API_KEY=your_openweathermap_key_here

# Default location for weather module
DEFAULT_CITY=Ernakulam
DEFAULT_COUNTRY=IN
